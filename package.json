{
  "name": "sparxstar-data-gap",
  "version": "1.0.0",
  "description": "WordPress plugin — Neural Language Map. Build tooling for minification.",
  "private": true,
  "scripts": {
    "build": "npm run vendor:three && npm run build:js && npm run build:css",
    "build:js": "esbuild wp-content/plugins/sparxstar-data-gap/assets/js/neural-map.js --bundle --inject:scripts/three-inject.js --format=iife --platform=browser --minify --outfile=wp-content/plugins/sparxstar-data-gap/assets/js/neural-map.min.js",
    "build:css": "postcss wp-content/plugins/sparxstar-data-gap/assets/css/neural-map.css --use cssnano --no-map --output wp-content/plugins/sparxstar-data-gap/assets/css/neural-map.min.css",
    "vendor:three": "esbuild scripts/three-entry.js --bundle --format=iife --platform=browser --minify --outfile=wp-content/plugins/sparxstar-data-gap/assets/js/three.min.js"
  },
  "devDependencies": {
    "cssnano": "^7.0.7",
    "esbuild": "^0.25.4",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "three": "0.184.0"
  }
}
